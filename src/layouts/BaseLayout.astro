---
import { ViewTransitions } from "astro:transitions";
import { defaultLocale, getMessages } from "../i18n";
import PageBackground from "../features/home/background/PageBackground.astro";

interface Props {
  title?: string;
  description?: string;
  page?: "home" | "case" | "not-found" | "default";
}

const m = getMessages();

const {
  title = m.meta.defaultTitle,
  description = m.meta.defaultDescription,
  page = "default",
} = Astro.props;

const enablePageEnter = page === "home" || page === "case";
---

<!doctype html>
<html lang={defaultLocale} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/images/widgets/icon.svg" />
    <link
      rel="preload"
      href="/fonts/Comforter-Regular.ttf"
      as="font"
      type="font/ttf"
      crossorigin
    />
    <ViewTransitions />
    <style is:global>
      @import "../styles/global.css";
    </style>
  </head>
  <body data-page={page}>
    <PageBackground />
    {
      enablePageEnter && (
        <script is:inline>
          (function () {
            if (window.__pageEnterSkip) return;
            if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
            document.documentElement.dataset.homeEnter = "true";
          })();
        </script>
      )
    }
    <slot name="header" />
    <slot />
  </body>
</html>

<script>
  import "../features/home/HomeOrchestrator.client";
</script>
