---
import { ViewTransitions } from "astro:transitions";
import { getMessages, resolveLocale } from "../i18n";
import PageBackground from "../features/home/background/PageBackground.astro";
import { withBase } from "../lib/withBase";

interface Props {
  title?: string;
  description?: string;
  page?: "home" | "case" | "not-found" | "default";
}

const locale = resolveLocale(Astro.currentLocale);
const m = getMessages(locale);

const {
  title = m.meta.defaultTitle,
  description = m.meta.defaultDescription,
  page = "default",
} = Astro.props;

const enablePageEnter = page === "home" || page === "case";
const baseUrl = import.meta.env.BASE_URL;
const iconHref = withBase("/images/widgets/icon.svg");
const comforterFontHref = withBase("/fonts/Comforter-Regular.ttf");
---

<!doctype html>
<html lang={locale} data-theme="graphite">
  <head>
    {baseUrl !== "/" && <base href={baseUrl} />}
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={iconHref} />
    <link
      rel="preload"
      href={comforterFontHref}
      as="font"
      type="font/ttf"
      crossorigin
    />
    <ViewTransitions />
    <style is:global>
      @import "../styles/global.css";
    </style>
  </head>
  <body data-page={page}>
    <PageBackground />
    {
      enablePageEnter && (
        <script is:inline>
          (function () {
            if (window.__pageEnterSkip) return;
            if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
            document.documentElement.dataset.homeEnter = "true";
          })();
        </script>
      )
    }
    <slot name="header" />
    <slot />
  </body>
</html>

<script>
  import "../features/home/HomeOrchestrator.client";
</script>
