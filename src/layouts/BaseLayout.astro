---
import { ViewTransitions } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
  page?: "home" | "case" | "default";
}

const {
  title = "Портфолио",
  description = "Портфолио продуктового дизайнера",
  page = "default",
} = Astro.props;
---

<!doctype html>
<html lang="ru" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/images/widgets/icon.svg" />
    <ViewTransitions />
  </head>
  <body data-page={page}>
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>

<script>
  import "../features/home/HomeOrchestrator.client";
</script>
