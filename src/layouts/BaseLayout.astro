---
import { ViewTransitions } from "astro:transitions";
import { getMessages, resolveLocale } from "../i18n";
import PageBackground from "../features/home/background/PageBackground.astro";
import { withBase } from "../lib/withBase";

interface Props {
  title?: string;
  description?: string;
  page?: "home" | "case" | "not-found" | "default";
}

const locale = resolveLocale(Astro.currentLocale);
const m = getMessages(locale);

const {
  title = m.meta.defaultTitle,
  description = m.meta.defaultDescription,
  page = "default",
} = Astro.props;

const enablePageEnter = page === "home" || page === "case";
const baseUrl = import.meta.env.BASE_URL;
const iconHref = withBase("/images/widgets/icon.svg");
const comforterFontHref = withBase("/fonts/Comforter-Regular.ttf");
---

<!doctype html>
<html lang={locale} data-theme="graphite">
  <head>
    {baseUrl !== "/" && <base href={baseUrl} />}
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={iconHref} />
    <link
      rel="preload"
      href={comforterFontHref}
      as="font"
      type="font/ttf"
      crossorigin
    />
    <ViewTransitions />
    <style is:global>
      @import "../styles/global.css";
    </style>
  </head>
  <body data-page={page}>
    <PageBackground />
    {
      enablePageEnter && (
        <script is:inline>
          (function () {
            if (window.__pageEnterSkip) return;
            if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
            document.documentElement.dataset.homeEnter = "true";
          })();
        </script>
      )
    }
    <slot name="header" />
    <slot />
    <div class="mobile-stub" role="alert" aria-label={m.mobileStub.ariaLabel}>
      <p class="mobile-stub__text">{m.mobileStub.text}</p>
    </div>
  </body>
</html>

<style>
  .mobile-stub {
    display: none;
  }

  /* Below desktop (< 1024px, синхронно с --bp-desktop) — see layout-grid.mdc */
  @media (max-width: 1023px) {
    .mobile-stub {
      position: fixed;
      inset: 0;
      z-index: var(--z-mobile-stub);
      display: grid;
      place-items: center;
      padding: var(--space-xl);
      background: var(--color-bg-page);
    }

    .mobile-stub__text {
      margin: 0;
      max-width: 320px;
      color: var(--color-text-primary);
      font-family: var(--font-family);
      font-size: var(--font-size-lg);
      font-weight: var(--font-weight-medium);
      line-height: var(--line-height-tight);
      letter-spacing: var(--letter-spacing-tight);
      text-align: center;
      text-wrap: balance;
    }
  }
</style>

<script>
  import "../features/home/HomeOrchestrator.client";
</script>
