---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/layout/Header.astro";
import Grid from "../../components/layout/Grid.astro";
import CaseHero from "../../components/cases/CaseHero.astro";
import { caseMdxComponents } from "../../components/cases/blocks";
import HomeWidgets from "../home/HomeWidgets.astro";
import NavigationWidget from "../../widgets/navigation/NavigationWidget.astro";
import { getCaseTitle } from "../cases/getCaseTitle";
import { getMessages, resolveLocale } from "../../i18n";
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import "../home/home.layout.css";

interface Props {
  caseEntry: CollectionEntry<"cases">;
}

const { caseEntry } = Astro.props;
const locale = resolveLocale(Astro.currentLocale);
const { Content } = await render(caseEntry);
const { summary } = caseEntry.data;
const title = getCaseTitle(caseEntry.slug, locale);
const m = getMessages(locale);
---

<BaseLayout title={`${title} — ${m.meta.defaultTitle}`} description={summary} page="case">
  <Header slot="header" />

  <main class="home" data-case-page aria-label={title}>
    <Grid>
      <HomeWidgets slot="widgets" />

      <article slot="cases" class="home__cases case-content" data-case-content>
        <CaseHero caseEntry={caseEntry} />
        <div class="case-content__body" data-case-content-body>
          <Content components={caseMdxComponents} />
        </div>
      </article>
    </Grid>

    <p class="home__copyright" data-page-enter>krgzv.com © 2026</p>
  </main>

  <NavigationWidget />
</BaseLayout>
