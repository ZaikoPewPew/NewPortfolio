<div id="case-preview-panel" class="case-preview" aria-hidden="true">
  <img class="case-preview__image" data-preview-image alt="" width="200" height="120" hidden />
  <p class="case-preview__title" data-preview-title></p>
</div>

<style>
  .case-preview {
    position: fixed;
    right: var(--space-2xl);
    top: 50%;
    transform: translateY(-50%) scale(0.92);
    opacity: 0;
    pointer-events: none;
    z-index: var(--z-preview);
    padding: var(--space-md);
    border-radius: var(--radius-card);
    background: color-mix(in srgb, var(--color-bg-elevated) 85%, transparent);
    backdrop-filter: blur(12px);
    border: 1px solid var(--color-border-subtle);
    transition:
      opacity var(--motion-base) var(--ease-out-expo),
      transform var(--motion-base) var(--ease-out-expo);
    max-width: 240px;
  }

  .case-preview.is-visible {
    opacity: 1;
    transform: translateY(-50%) scale(1);
  }

  .case-preview__image {
    width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-sm);
  }

  .case-preview__title {
    font-size: var(--font-size-sm);
    color: var(--color-text-primary);
  }

  @media (max-width: 639px) {
    .case-preview {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .case-preview {
      transition: none;
    }
  }
</style>
