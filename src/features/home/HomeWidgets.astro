---
import MeWidget from "../../widgets/me/MeWidget.astro";
import ContactWidget from "../../widgets/me/ContactWidget.astro";
import GitWidget from "../../widgets/git/GitWidget.astro";
import BookWidget from "../../widgets/book/BookWidget.astro";
import PhotoWidget from "../../widgets/photo/PhotoWidget.astro";
import BentoWidget from "../../widgets/bento/BentoWidget.astro";
import { resolveLocale } from "../../i18n";
import { CONTACT_PANEL_OPEN_KEY } from "./contact/contact-panel.storage";
import "../home/contact/contact-panel.animations.css";

const locale = resolveLocale(Astro.currentLocale);
---

<div
  class="home__widgets"
  data-contact-layout
  data-contact-open="true"
  transition:persist={`home-widgets-${locale}`}
>
  <script is:inline define:vars={{ contactPanelOpenKey: CONTACT_PANEL_OPEN_KEY }}>
    (function () {
      if (window.matchMedia("(max-width: 639px)").matches) return;

      var value = sessionStorage.getItem(contactPanelOpenKey);
      if (value === null) return;

      var open = value === "1" || value === "true";

      var layout = document.currentScript && document.currentScript.parentElement;
      if (layout && layout.hasAttribute("data-contact-layout")) {
        layout.dataset.contactOpen = String(open);
      }
    })();
  </script>
  <MeWidget />
  <div class="home__contact-mobile" data-page-enter>
    <ContactWidget />
  </div>

  <div class="home__widgets-body">
    <div class="home__widgets-default" data-contact-default>
      <div
        class="home__widget-item home__widget-item--git"
        data-contact-item="git"
        data-tooltip-layer
        data-page-enter
      >
        <GitWidget />
      </div>
      <div class="home__widget-row" data-contact-item="row">
        <div class="home__widget-stack">
          <div data-contact-item="book" data-page-enter>
            <BookWidget />
          </div>
          <div data-contact-item="bento" data-tooltip-layer data-page-enter>
            <BentoWidget section="links" />
          </div>
        </div>
        <div
          class="home__widget-stack"
          data-contact-item="photo"
          data-tooltip-layer
          data-page-enter
        >
          <PhotoWidget />
          <BentoWidget section="youtube" />
        </div>
      </div>
    </div>

    <div class="home__contact-slot" data-contact-slot aria-hidden="true">
      <div class="home__contact-slot-enter" data-page-enter>
        <ContactWidget />
      </div>
    </div>
  </div>
</div>

<style>
  .home__widgets {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--bento-gap);
    width: var(--layout-widgets-width);
    max-width: var(--layout-widgets-width);
    box-sizing: border-box;
  }

  .home__widgets > .me-widget {
    position: relative;
    z-index: 4;
  }

  .home__widget-row {
    display: flex;
    gap: var(--bento-gap);
    align-items: flex-start;
  }

  .home__widget-stack {
    display: flex;
    flex-direction: column;
    gap: var(--bento-gap);
    width: var(--widget-book-size);
  }

  .home__widgets-body {
    position: relative;
    min-height: 292px;
    overflow: visible;
    z-index: 1;
  }

  .home__widgets-default {
    display: flex;
    flex-direction: column;
    gap: var(--bento-gap);
    position: relative;
    z-index: 1;
  }

  .home__contact-slot {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
  }

  .home__contact-slot-enter {
    width: 100%;
    height: 100%;
  }

  .home__widgets[data-contact-open="true"] .home__widgets-default,
  .home__widgets[data-contact-animating] .home__widgets-default {
    pointer-events: none;
  }

  .home__widget-item--git,
  [data-contact-item="book"],
  [data-contact-item="photo"],
  [data-contact-item="bento"] {
    position: relative;
  }

  .home__widget-item--git {
    z-index: -1;
  }

  .home__widgets[data-contact-open="true"] .home__contact-slot,
  .home__widgets[data-contact-animating="opening"] .home__contact-slot {
    pointer-events: auto;
  }

  .home__contact-mobile {
    display: none;
  }

  @media (max-width: 639px) {
    .home__widgets {
      width: 100%;
      max-width: 100%;
      gap: var(--layout-gutter-mobile);
    }

    .home__contact-mobile {
      display: block;
      width: 100%;
    }

    .home__widgets-body {
      display: none;
    }

    /* Case page: contacts stay off (widgets column hidden in home.layout.css) */
    :global(body[data-page="case"]) .home__contact-mobile {
      display: none;
    }
  }
</style>
