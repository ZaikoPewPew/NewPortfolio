---
import { siteConfig } from "../../../config/site.config";
---

<header class="site-header">
  <p class="site-header__employer">
    {siteConfig.employer.prefix}
    <span class="site-header__employer-name">{siteConfig.employer.label}</span>
  </p>
  <p class="site-header__location" data-live-clock>
    {siteConfig.location.city}
    <span data-clock-time>--:--</span>
  </p>
</header>

<script>
  import { siteConfig } from "../../../config/site.config";

  function updateClock() {
    const el = document.querySelector("[data-clock-time]");
    if (!el) return;
    const time = new Intl.DateTimeFormat("en-US", {
      timeZone: siteConfig.location.timezone,
      hour: "numeric",
      minute: "2-digit",
      hour12: true,
    }).format(new Date());
    el.textContent = time;
  }

  updateClock();
  setInterval(updateClock, 60_000);
</script>

<style>
  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .site-header__employer-name {
    color: var(--color-accent);
    font-weight: var(--font-weight-medium);
  }

  .site-header__location {
    display: flex;
    gap: var(--space-sm);
    white-space: nowrap;
  }
</style>
