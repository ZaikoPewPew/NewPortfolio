---
import Tooltip from "../../components/ui/Tooltip.astro";
import { getMessages } from "../../i18n";
import { getBentoData } from "./data/bento.source";
import "./bento.styles.css";
import "./bento.animations.css";

const data = await getBentoData();
const m = getMessages();
const topTiles = data.tiles.filter((tile) => tile.variant !== "youtube");
const youtubeTile = data.tiles.find((tile) => tile.variant === "youtube");
---

