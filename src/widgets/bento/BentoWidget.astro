<script>
  import { initDragTooltips } from "../../components/ui/tooltip.client";
  import { feedback } from "../../experience/feedback/FeedbackBus";

  function bindBentoTiles() {
    initDragTooltips();

    document.querySelectorAll("[data-bento-tile]").forEach((tile) => {
      if (tile.hasAttribute("data-bound")) return;
      tile.setAttribute("data-bound", "true");
      tile.addEventListener("click", () => {
        feedback.emit({
          sound: "tap",
          haptic: "light",
          source: `widget.bento.${(tile as HTMLElement).dataset.bentoTile}`,
        });
      });
    });
  }

  bindBentoTiles();
  document.addEventListener("astro:page-load", bindBentoTiles);
</script>
