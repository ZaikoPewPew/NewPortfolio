---
import { spotifyConfig } from "./config";
import { getSpotifyPlayback } from "./data/spotify.source";
import "./spotify.styles.css";
import "./spotify.animations.css";

const playback = await getSpotifyPlayback();
const currentTrack = playback.tracks[playback.currentIndex];
---

<article
  class="spotify-widget"
  aria-label={spotifyConfig.ariaLabel}
  data-spotify-widget
  data-tracks={JSON.stringify(playback.tracks)}
  data-current-index={playback.currentIndex}
  data-is-playing={String(playback.isPlaying)}
>
  <svg
    class="spotify-widget__logo"
    width="24"
    height="24"
    viewBox="0 0 24 24"
    fill="none"
    aria-hidden="true"
  >
    <path
      d="M11.9633 0C5.35629 0 0 5.35614 0 11.9631C0 18.5704 5.35629 23.9261 11.9633 23.9261C18.571 23.9261 23.9267 18.5704 23.9267 11.9631C23.9267 5.35657 18.571 0.000571425 11.9631 0.000571425L11.9633 0ZM17.4496 17.2543C17.2353 17.6057 16.7753 17.7171 16.4239 17.5014C13.615 15.7857 10.079 15.3971 5.91471 16.3486C5.51343 16.44 5.11343 16.1886 5.022 15.7871C4.93014 15.3857 5.18057 14.9857 5.58286 14.8943C10.14 13.8527 14.049 14.3014 17.2024 16.2286C17.5539 16.4443 17.6653 16.9029 17.4496 17.2543ZM18.9139 13.9964C18.6439 14.4357 18.0696 14.5743 17.631 14.3043C14.4153 12.3273 9.51343 11.7549 5.70986 12.9094C5.21657 13.0584 4.69557 12.7804 4.54586 12.288C4.39729 11.7947 4.67543 11.2747 5.16786 11.1247C9.51257 9.80643 14.9139 10.445 18.6067 12.7143C19.0453 12.9843 19.1839 13.5584 18.9139 13.9964ZM19.0396 10.6044C15.1839 8.31429 8.82243 8.10371 5.14114 9.221C4.55 9.40029 3.92486 9.06657 3.74571 8.47543C3.56657 7.884 3.9 7.25929 4.49157 7.07957C8.71743 5.79671 15.7424 6.04457 20.1816 8.67986C20.7144 8.99543 20.8887 9.68214 20.573 10.2131C20.2587 10.7449 19.5701 10.9201 19.0401 10.6044H19.0396Z"
      fill="currentColor"></path>
  </svg>

  <div class="spotify-widget__track">
    <p class="spotify-widget__title" data-spotify-title>{currentTrack.title}</p>
    <p class="spotify-widget__artist" data-spotify-artist>{currentTrack.artist}</p>
  </div>

  <div class="spotify-widget__controls">
    <button
      type="button"
      class="spotify-widget__control"
      data-spotify-action="play"
      aria-label="Воспроизвести"
    >
      <svg
        class="spotify-widget__control-icon"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M8 6V18M11.4761 12.7809L16.3753 16.7002C17.0301 17.2241 18 16.7579 18 15.9194V8.08062C18 7.24212 17.0301 6.77595 16.3753 7.29976L11.4761 11.2191C10.9757 11.6195 10.9757 12.3805 11.4761 12.7809Z"
          stroke="currentColor"
          stroke-width="1.3"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </button>

    <button
      type="button"
      class="spotify-widget__control"
      data-spotify-action="pause"
      aria-label="Пауза"
    >
      <svg
        class="spotify-widget__control-icon"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M7 16V8C7 7.44772 7.44772 7 8 7H9C9.55228 7 10 7.44772 10 8V16C10 16.5523 9.55228 17 9 17H8C7.44772 17 7 16.5523 7 16Z"
          stroke="currentColor"
          stroke-width="1.3"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
        <path
          d="M14 16V8C14 7.44772 14.4477 7 15 7H16C16.5523 7 17 7.44772 17 8V16C17 16.5523 16.5523 17 16 17H15C14.4477 17 14 16.5523 14 16Z"
          stroke="currentColor"
          stroke-width="1.3"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </button>

    <button
      type="button"
      class="spotify-widget__control"
      data-spotify-action="prev"
      aria-label="Предыдущий трек"
    >
      <svg
        class="spotify-widget__control-icon"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M17 6V18M13.5239 12.7809L8.6247 16.7002C7.96993 17.2241 7 16.7579 7 15.9194V8.08062C7 7.24212 7.96993 6.77595 8.6247 7.29976L13.5239 11.2191C14.0243 11.6195 14.0243 12.3805 13.5239 12.7809Z"
          stroke="currentColor"
          stroke-width="1.3"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </button>
  </div>
</article>

<script>
  import { feedback } from "../../experience/feedback/FeedbackBus";

  interface SpotifyTrack {
    title: string;
    artist: string;
  }

  function initSpotifyWidget(widget: HTMLElement) {
    if (widget.hasAttribute("data-bound")) return;
    widget.setAttribute("data-bound", "true");

    const tracks = JSON.parse(widget.dataset.tracks ?? "[]") as SpotifyTrack[];
    let currentIndex = Number(widget.dataset.currentIndex ?? 0);
    let isPlaying = widget.dataset.isPlaying === "true";

    const titleEl = widget.querySelector<HTMLElement>("[data-spotify-title]");
    const artistEl = widget.querySelector<HTMLElement>("[data-spotify-artist]");

    if (!titleEl || !artistEl || tracks.length === 0) return;

    const updateTrack = () => {
      const track = tracks[currentIndex];
      titleEl.textContent = track.title;
      artistEl.textContent = track.artist;
      widget.dataset.currentIndex = String(currentIndex);
    };

    const updatePlayState = () => {
      widget.dataset.isPlaying = String(isPlaying);
    };

    const changeTrack = (direction: -1 | 1) => {
      currentIndex = (currentIndex + direction + tracks.length) % tracks.length;
      updateTrack();
    };

    updatePlayState();

    widget.querySelectorAll("[data-spotify-action]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const action = (btn as HTMLElement).dataset.spotifyAction;

        if (action === "play") {
          isPlaying = true;
          updatePlayState();
        }

        if (action === "pause") {
          isPlaying = false;
          updatePlayState();
        }

        if (action === "prev") changeTrack(-1);

        feedback.emit({ sound: "tap", haptic: "light", source: "widget.spotify" });
      });
    });
  }

  document.querySelectorAll("[data-spotify-widget]").forEach((widget) => {
    initSpotifyWidget(widget as HTMLElement);
  });

  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll("[data-spotify-widget]").forEach((widget) => {
      initSpotifyWidget(widget as HTMLElement);
    });
  });
</script>
