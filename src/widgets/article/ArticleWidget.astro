---
import { getMessages, resolveLocale } from "../../i18n";
import "./article.styles.css";
import "./article.animations.css";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const locale = resolveLocale(Astro.currentLocale);
const m = getMessages(locale);
---

<nav
  class:list={["article-widget", className]}
  aria-label={m.articleWidget.ariaLabel}
  data-article-widget
>
  {/* Section names column — collapsed shows the active + neighbours, a tap
      expands into the full list. JS creates and positions each name. */}
  <div class="article-widget__names" data-article-names></div>
</nav>

<script>
  import { initArticleWidget } from "./article.client";

  initArticleWidget();
  document.addEventListener("astro:page-load", () => initArticleWidget());
</script>
