---
import type { WidgetLayout } from "./types";

interface Props {
  label?: string;
  ariaLabel: string;
  layout?: WidgetLayout;
  class?: string;
}

const { label, ariaLabel, layout = "square", class: className } = Astro.props;
---

<article
  class:list={["widget-shell", `widget-shell--${layout}`, className]}
  aria-label={ariaLabel}
>
  <div class="widget-shell__content">
    <slot />
  </div>
  {label && <p class="widget-shell__label">{label}</p>}
</article>

<style>
  .widget-shell {
    position: relative;
    background: var(--color-bg-surface);
    border-radius: var(--radius-widget);
    overflow: hidden;
    width: 100%;
    height: 100%;
    min-height: var(--bento-cell-size);
  }

  .widget-shell--square {
    aspect-ratio: 1;
    max-width: var(--bento-cell-size);
  }

  .widget-shell--wide {
    min-height: calc(var(--bento-cell-size) + var(--space-lg));
  }

  .widget-shell__content {
    position: absolute;
    inset: 0;
  }

  .widget-shell__label {
    position: absolute;
    left: 50%;
    bottom: var(--space-md);
    transform: translateX(-50%);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-regular);
    color: var(--color-text-primary);
    text-align: center;
    white-space: nowrap;
    z-index: 1;
  }
</style>
