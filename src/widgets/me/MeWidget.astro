---
import ContactButton from "../../components/ui/ContactButton.astro";
import ThemeToggle from "../../components/ui/ThemeToggle.astro";
import { getMessages } from "../../i18n";
import { getMeProfile } from "./data/me.source";
import "./me.styles.css";

const profile = await getMeProfile();
const m = getMessages();
---

<article class="me-widget" aria-label={m.me.ariaLabel} data-page-enter>
  <div class="me-widget__header">
    <img
      class="me-widget__avatar"
      src={profile.avatarUrl}
      alt=""
      width="48"
      height="48"
      loading="eager"
    />
    <div class="me-widget__identity">
      <p class="me-widget__name">{profile.name}</p>
      <p class="me-widget__role">{profile.role}</p>
    </div>
    <ThemeToggle />
  </div>

  <p class="me-widget__bio me-widget__desktop-only">
    <span class="me-widget__bio-line">{profile.bioLine1}</span>
    <span class="me-widget__bio-line">{profile.bioLine2}</span>
  </p>

  <div class="me-widget__desktop-only">
    <ContactButton />
  </div>
</article>
