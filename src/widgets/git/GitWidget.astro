---
import Tooltip from "../../components/ui/Tooltip.astro";
import { defaultLocale, getMessages, interpolate } from "../../i18n";
import { GIT_HEATMAP_COLS, GIT_HEATMAP_SIZE } from "./data/git.constants";
import { getGitProfile } from "./data/git.source";
import { formatContributionDate } from "./formatContributionDate";
import "./git.styles.css";
import "./git.animations.css";

const profile = await getGitProfile();
const m = getMessages();
const commitsPerYearLabel = interpolate(m.git.commitsPerYear, {
  count: new Intl.NumberFormat(defaultLocale).format(profile.commitsPerYear),
});
const lastRowStartIndex = GIT_HEATMAP_SIZE - GIT_HEATMAP_COLS;

const levelClass = (level: number) =>
  level === 0 ? "" : `git-widget__cell--l${level}`;
---

<div class="git-widget-shell">
  <div
    class="git-widget"
    data-git-widget
    data-git-profile-url={profile.profileUrl}
    data-feedback="hover"
    data-feedback-source="widget.git"
  >
    <a
      class="git-widget__header"
      href={profile.profileUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={m.git.ariaLabel}
    >
      <svg
        class="git-widget__icon"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        aria-hidden="true"
      >
        <path
          fill-rule="evenodd"
          clip-rule="evenodd"
          d="M12.0099 0C5.36875 0 0 5.40833 0 12.0992C0 17.4475 3.43994 21.9748 8.21205 23.5771C8.80869 23.6976 9.02724 23.3168 9.02724 22.9965C9.02724 22.716 9.00757 21.7545 9.00757 20.7527C5.6667 21.474 4.97099 19.3104 4.97099 19.3104C4.43409 17.9082 3.63858 17.5478 3.63858 17.5478C2.54511 16.8066 3.71823 16.8066 3.71823 16.8066C4.93117 16.8868 5.56763 18.0486 5.56763 18.0486C6.64118 19.8913 8.37111 19.3707 9.06706 19.0501C9.16638 18.2688 9.48473 17.728 9.82275 17.4276C7.15817 17.1471 4.35469 16.1055 4.35469 11.458C4.35469 10.1359 4.8316 9.05428 5.58729 8.21304C5.46807 7.91263 5.0504 6.67043 5.70677 5.00787C5.70677 5.00787 6.72083 4.6873 9.00732 6.24981C9.98625 5.98497 10.9958 5.85024 12.0099 5.84911C13.024 5.84911 14.0577 5.98948 15.0123 6.24981C17.299 4.6873 18.3131 5.00787 18.3131 5.00787C18.9695 6.67043 18.5515 7.91263 18.4323 8.21304C19.2079 9.05428 19.6652 10.1359 19.6652 11.458C19.6652 16.1055 16.8617 17.1269 14.1772 17.4276C14.6148 17.8081 14.9924 18.5292 14.9924 19.6711C14.9924 21.2936 14.9727 22.5957 14.9727 22.9962C14.9727 23.3168 15.1915 23.6976 15.7879 23.5774C20.56 21.9745 23.9999 17.4475 23.9999 12.0992C24.0196 5.40833 18.6312 0 12.0099 0Z"
          fill="currentColor"></path>
      </svg>
      <span class="git-widget__username">
        <span class="git-widget__username-layer git-widget__username-layer--default">
          {profile.username}
        </span>
        <span
          class="git-widget__username-layer git-widget__username-layer--commits"
          aria-hidden="true"
        >
          {commitsPerYearLabel}
        </span>
      </span>
    </a>

    <a
      class="git-widget__heatmap"
      href={profile.profileUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={m.git.openProfile}
    >
      {
        profile.heatmap.map((day, index) => (
          <span
            class:list={["git-widget__cell", levelClass(day.level)]}
            data-git-cell
            data-tooltip-label={
              index < lastRowStartIndex
                ? formatContributionDate(day.date)
                : undefined
            }
          />
        ))
      }
    </a>
  </div>

  <div class="git-widget__tooltip-host" data-git-tooltip-host>
    <Tooltip class="git-widget__tooltip" lines={[""]} />
  </div>
</div>

<script>
  import { initGitWidget } from "./git.client";

  function bindGitWidgets() {
    document.querySelectorAll("[data-git-widget]").forEach((widget) => {
      initGitWidget(widget as HTMLElement);
    });
  }

  bindGitWidgets();
  document.addEventListener("astro:page-load", bindGitWidgets);
</script>
