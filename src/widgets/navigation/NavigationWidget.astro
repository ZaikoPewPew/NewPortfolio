---
import { getRelativeLocaleUrl } from "astro:i18n";
import { getMessages, resolveLocale } from "../../i18n";
import "./navigation.styles.css";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const locale = resolveLocale(Astro.currentLocale);
const m = getMessages(locale);
const homeHref = getRelativeLocaleUrl(locale, "/");
---

<nav
  class:list={["navigation-widget", className]}
  aria-label={m.navigationWidget.ariaLabel}
  data-navigation-widget
>
  <a
    class="navigation-widget__btn"
    href={homeHref}
    data-astro-reload
    data-feedback="tap hover"
    data-feedback-source="widget.navigation.home"
    aria-label={m.navigationWidget.homeAriaLabel}
  >
    <svg
      class="navigation-widget__icon"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
    >
      <path
        d="M11 18L5 12L11 6M5 12H19"
        stroke="currentColor"
        stroke-width="1.3"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </a>

  <button
    type="button"
    class="navigation-widget__btn navigation-widget__btn--scroll-top"
    data-navigation-scroll-top
    data-feedback="tap hover"
    data-feedback-source="widget.navigation.scrollTop"
    aria-label={m.navigationWidget.scrollTopAriaLabel}
  >
    <svg
      class="navigation-widget__icon"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
    >
      <path
        d="M12 19V5M18 11L12 5L6 11"
        stroke="currentColor"
        stroke-width="1.3"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
    <svg
      class="navigation-widget__ring"
      viewBox="0 0 48 48"
      fill="none"
      aria-hidden="true"
    >
      {/* Rounded-rect outline starting at top center, clockwise; pathLength
          normalizes to 100 so dashoffset maps 1:1 to scroll percent. */}
      <path
        class="navigation-widget__ring-path"
        d="M24 1 H32 A15 15 0 0 1 47 16 V32 A15 15 0 0 1 32 47 H16 A15 15 0 0 1 1 32 V16 A15 15 0 0 1 16 1 H24"
        pathLength="100"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"></path>
    </svg>
  </button>
</nav>

<script>
  import { initNavigationWidget } from "./navigation.client";

  initNavigationWidget();
  document.addEventListener("astro:page-load", () => initNavigationWidget());
</script>
