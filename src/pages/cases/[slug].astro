---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/layout/Header.astro";
import Grid from "../../components/layout/Grid.astro";
import CaseHero from "../../components/cases/CaseHero.astro";
import HomeWidgets from "../../features/home/HomeWidgets.astro";
import { getCollection, render } from "astro:content";
import "../../features/home/home.layout.css";

export async function getStaticPaths() {
  const cases = await getCollection("cases");
  return cases.map((caseEntry) => ({
    params: { slug: caseEntry.slug },
    props: { caseEntry },
  }));
}

const { caseEntry } = Astro.props;
const { Content } = await render(caseEntry);
const { title, summary } = caseEntry.data;
---

<BaseLayout title={`${title} — Портфолио`} description={summary} page="case">
  <Header slot="header" />

  <main class="home" data-case-page aria-label={title}>
    <Grid>
      <HomeWidgets slot="widgets" />

      <article slot="cases" class="home__cases case-content" data-case-content>
        <CaseHero caseEntry={caseEntry} />
        <div class="case-content__body" data-case-content-body>
          <Content />
        </div>
      </article>
    </Grid>

    <p class="home__copyright">krgzv.com © 2026</p>
  </main>
</BaseLayout>
