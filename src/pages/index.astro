---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/layout/Header.astro";
import Grid from "../components/layout/Grid.astro";
import CaseList from "../components/cases/CaseList.astro";
import ConceptBento from "../components/concepts/ConceptBento.astro";
import HomeWidgets from "../features/home/HomeWidgets.astro";
import { getHomeCases } from "../features/home/cases/getHomeCases";
import { getMessages } from "../i18n";
import "../features/home/home.layout.css";

const homeCases = await getHomeCases();
const m = getMessages();
---

<BaseLayout title={m.meta.homeTitle} page="home">
  <Header slot="header" />

  <main class="home" data-home-page aria-label={m.home.ariaLabel}>
    <Grid>
      <HomeWidgets slot="widgets" />

      <div slot="cases" class="home__cases">
        <CaseList cases={homeCases} />
        <ConceptBento />
      </div>
    </Grid>

    <p class="home__copyright" data-page-enter>krgzv.com © 2026</p>
  </main>
</BaseLayout>
