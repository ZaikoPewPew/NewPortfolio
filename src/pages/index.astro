---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageShell from "../components/layout/PageShell.astro";
import Grid from "../components/layout/Grid.astro";
import WidgetGrid from "../components/layout/WidgetGrid.astro";
import CaseList from "../components/cases/CaseList.astro";
import PageBackground from "../features/home/background/PageBackground.astro";
import SiteHeader from "../features/home/header/SiteHeader.astro";
import ActionDock from "../features/home/dock/ActionDock.astro";
import CasePreviewPanel from "../features/home/case-hover/CasePreviewPanel.astro";
import { getCollection } from "astro:content";

const cases = (await getCollection("cases")).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout title="Портфолио — Продуктовый дизайнер" page="home">
  <PageBackground />
  <PageShell>
    <main class="page" data-home-page>
      <SiteHeader />
      <Grid>
        <WidgetGrid slot="widgets" />
        <CaseList slot="cases" cases={cases} />
      </Grid>
    </main>
    <ActionDock />
    <CasePreviewPanel />
  </PageShell>
</BaseLayout>
