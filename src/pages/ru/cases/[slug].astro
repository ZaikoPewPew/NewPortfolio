---
import CasePage from "../../../features/cases/CasePage.astro";
import { getPublishedCases } from "../../../features/cases/getPublishedCases";

export async function getStaticPaths() {
  const cases = await getPublishedCases();
  return cases.map((caseEntry) => ({
    params: { slug: caseEntry.slug },
    props: { caseEntry },
  }));
}

const { caseEntry } = Astro.props;
---

<CasePage caseEntry={caseEntry} />
