---
import { getMessages } from "../../i18n";

type ContactButtonMode = "contact" | "about";

interface Props {
  hotkey?: string;
  class?: string;
  mode?: ContactButtonMode;
}

const { hotkey = "h", class: className, mode = "contact" } = Astro.props;
const m = getMessages();

const labelByMode: Record<ContactButtonMode, string> = {
  contact: m.me.contactButton.contact,
  about: m.me.contactButton.about,
};

const keycapByMode: Record<ContactButtonMode, string> = {
  contact: hotkey,
  about: "c",
};
---

<button
  type="button"
  class:list={["contact-button", className]}
  data-feedback="bubble"
  data-feedback-source="contact.button"
  data-contact-button
  aria-expanded={mode === "about" ? "true" : "false"}
>
  <span class="contact-button__fill" aria-hidden="true"></span>
  <span class="contact-button__label" data-contact-button-label>
    {labelByMode[mode]}
  </span>
  {
    keycapByMode[mode] && (
      <span class="contact-button__keycap" aria-hidden="true" data-contact-button-keycap>
        <span class="contact-button__keycap-char" data-contact-button-keycap-char>
          {keycapByMode[mode]}
        </span>
      </span>
    )
  }
</button>

<style>
  .contact-button {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: var(--space-md) var(--space-lg);
    border: none;
    border-radius: var(--radius-control);
    background: var(--color-bg-contrast);
    color: var(--color-text-on-contrast);
    font-family: var(--font-family);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-normal);
    text-align: center;
    cursor: pointer;
    overflow: hidden;
    isolation: isolate;
  }

  .contact-button__fill {
    position: absolute;
    inset: 0;
    background: var(--color-contact-button-hover-bg);
    clip-path: circle(0% at 50% 50%);
    transition: clip-path var(--motion-contact-button-fill) var(--ease-contact-button-fill);
    z-index: 0;
    pointer-events: none;
  }

  .contact-button__label {
    position: relative;
    z-index: 1;
    white-space: nowrap;
    transition: color var(--motion-contact-button-text) ease;
  }

  .contact-button[data-contact-hover] .contact-button__label {
    color: var(--color-contact-button-hover-text);
  }

  .contact-button__keycap {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--keycap-size);
    height: var(--keycap-size);
    border: 1px solid var(--color-text-on-contrast);
    border-bottom-width: var(--keycap-border-bottom);
    border-radius: var(--radius-keycap);
    opacity: 0.15;
    transition:
      border-color var(--motion-contact-button-text) ease,
      opacity var(--motion-contact-button-text) ease;
  }

  .contact-button[data-contact-hover] .contact-button__keycap {
    border-color: var(--color-contact-button-hover-text);
    opacity: 0.35;
  }

  .contact-button__keycap-char {
    font-size: var(--font-size-sm);
    line-height: 1;
    color: var(--color-text-on-contrast);
    transition: color var(--motion-contact-button-text) ease;
  }

  .contact-button[data-contact-hover] .contact-button__keycap-char {
    color: var(--color-contact-button-hover-text);
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-button__fill {
      display: none;
    }

    .contact-button[data-contact-hover] {
      background: var(--color-contact-button-hover-bg);
    }

    .contact-button[data-contact-hover] .contact-button__label,
    .contact-button[data-contact-hover] .contact-button__keycap-char {
      color: var(--color-contact-button-hover-text);
    }

    .contact-button[data-contact-hover] .contact-button__keycap {
      border-color: var(--color-contact-button-hover-text);
      opacity: 0.35;
    }
  }
</style>
