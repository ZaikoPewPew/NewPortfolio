---
interface Props {
  lines: string[];
  class?: string;
  /** Default: above the host. Theme toggle uses `bottom`. */
  placement?: "top" | "bottom";
}

const { lines, class: className, placement = "top" } = Astro.props;
const isBottom = placement === "bottom";
---

<div
  class:list={["tooltip", isBottom && "tooltip--bottom", className]}
  data-tooltip-placement={placement}
  role="tooltip"
  aria-hidden="true"
>
  <div class="tooltip__balloon">
    {isBottom && <div class="tooltip__caret tooltip__caret--up" aria-hidden="true" />}
    <div class="tooltip__content">
      {lines.map((line) => <p class="tooltip__line">{line}</p>)}
    </div>
    {!isBottom && <div class="tooltip__caret" aria-hidden="true" />}
  </div>
</div>

<style>
  .tooltip {
    position: absolute;
    bottom: calc(100% + var(--tooltip-offset));
    left: calc(50% + var(--tooltip-shift-x, 0px));
    z-index: var(--z-tooltip);
    width: max-content;
    max-width: 240px;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transform: translateX(-50%);
    transition:
      opacity var(--motion-tooltip-enter) var(--ease-spring-soft),
      visibility var(--motion-tooltip-enter) var(--ease-spring-soft);
    will-change: left;
  }

  .tooltip--bottom {
    top: calc(100% + var(--tooltip-offset));
    bottom: auto;
  }

  :global([data-tooltip-visible]) .tooltip,
  :global([data-tooltip-host]:focus-within:not([data-tooltip-dismissed])) .tooltip {
    opacity: 1;
    visibility: visible;
  }

  .tooltip__balloon {
    display: flex;
    flex-direction: column;
    align-items: center;
    transform-origin: bottom center;
    translate: 0 var(--tooltip-enter-offset, var(--space-2xs));
    scale: var(--tooltip-enter-scale, var(--tooltip-enter-scale-from));
    rotate: var(--tooltip-tilt, 0deg);
    transition:
      translate var(--motion-tooltip-enter) var(--ease-spring-soft),
      scale var(--motion-tooltip-enter) var(--ease-spring-soft);
    will-change: rotate, translate, scale;
  }

  .tooltip--bottom .tooltip__balloon {
    transform-origin: top center;
    translate: 0 calc(-1 * var(--tooltip-enter-offset, var(--space-2xs)));
  }

  :global([data-tooltip-visible]) .tooltip__balloon,
  :global([data-tooltip-host]:focus-within:not([data-tooltip-dismissed])) .tooltip__balloon {
    --tooltip-enter-offset: 0px;
    --tooltip-enter-scale: 1;
  }

  .tooltip__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--tooltip-line-gap);
    padding: var(--space-control);
    border-radius: var(--radius-tooltip);
    background: var(--color-tooltip-bg);
    box-shadow: var(--shadow-tooltip);
  }

  .tooltip__line {
    margin: 0;
    font-family: var(--font-family);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-tooltip);
    color: var(--color-tooltip-text);
    text-align: center;
    white-space: nowrap;
  }

  .tooltip__caret {
    flex-shrink: 0;
    width: 16px;
    height: calc(var(--space-sm) + var(--space-2xs));
    margin-top: calc(-1 * var(--space-2xs));
    background: var(--color-tooltip-bg);
    clip-path: polygon(50% 100%, 0 0, 100% 0);
  }

  .tooltip__caret--up {
    margin-top: 0;
    margin-bottom: calc(-1 * var(--space-2xs));
    clip-path: polygon(50% 0, 0 100%, 100% 100%);
  }

  @media (prefers-reduced-motion: reduce) {
    .tooltip {
      will-change: auto;
    }

    .tooltip__balloon {
      translate: 0 0;
      scale: 1;
      rotate: 0deg;
      transition:
        opacity var(--motion-tooltip-enter) var(--ease-spring-soft),
        visibility var(--motion-tooltip-enter) var(--ease-spring-soft);
      will-change: auto;
    }
  }
</style>
