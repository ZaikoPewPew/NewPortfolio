---
import "./tooltip.styles.css";

interface Props {
  lines: string[];
  class?: string;
  /** Default: above the host. Theme toggle uses `bottom`; bento side tiles use `left`/`right`. */
  placement?: "top" | "bottom" | "left" | "right";
}

const { lines, class: className, placement = "top" } = Astro.props;
---

<div
  class:list={[
    "tooltip",
    placement === "bottom" && "tooltip--bottom",
    placement === "left" && "tooltip--left",
    placement === "right" && "tooltip--right",
    className,
  ]}
  data-tooltip-placement={placement}
  role="tooltip"
  aria-hidden="true"
>
  <div class="tooltip__balloon">
    {
      placement === "bottom" && (
        <div class="tooltip__caret tooltip__caret--up" aria-hidden="true" />
      )
    }
    {
      placement === "right" && (
        <div class="tooltip__caret tooltip__caret--side tooltip__caret--left" aria-hidden="true" />
      )
    }
    <div class="tooltip__content">
      {lines.map((line) => <p class="tooltip__line">{line}</p>)}
    </div>
    {
      placement === "top" && (
        <div class="tooltip__caret" aria-hidden="true" />
      )
    }
    {
      placement === "left" && (
        <div class="tooltip__caret tooltip__caret--side tooltip__caret--right" aria-hidden="true" />
      )
    }
  </div>
</div>
