---
import "./tooltip.styles.css";

interface Props {
  lines: string[];
  class?: string;
  /** Default: above the host. Theme menu uses `left`; bento tiles use `bottom`. */
  placement?: "top" | "bottom" | "left" | "right";
  /** Hotkey hint rendered as a keycap next to the text (e.g. `t`, `s`, `l`). */
  keycap?: string;
}

const { lines, class: className, placement = "top", keycap } = Astro.props;
---

<div
  class:list={[
    "tooltip",
    placement === "bottom" && "tooltip--bottom",
    placement === "left" && "tooltip--left",
    placement === "right" && "tooltip--right",
    className,
  ]}
  data-tooltip-placement={placement}
  role="tooltip"
  aria-hidden="true"
>
  <div class="tooltip__balloon">
    {
      placement === "bottom" && (
        <div class="tooltip__caret tooltip__caret--up" aria-hidden="true" />
      )
    }
    {
      placement === "right" && (
        <div class="tooltip__caret tooltip__caret--side tooltip__caret--left" aria-hidden="true" />
      )
    }
    <div class:list={["tooltip__content", keycap && "tooltip__content--with-keycap"]}>
      <div class="tooltip__lines">
        {lines.map((line) => <p class="tooltip__line">{line}</p>)}
      </div>
      {
        keycap && (
          <span class="tooltip__keycap" aria-hidden="true">
            {keycap}
          </span>
        )
      }
    </div>
    {
      placement === "top" && (
        <div class="tooltip__caret" aria-hidden="true" />
      )
    }
    {
      placement === "left" && (
        <div class="tooltip__caret tooltip__caret--side tooltip__caret--right" aria-hidden="true" />
      )
    }
  </div>
</div>
