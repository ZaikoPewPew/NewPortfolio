---
import { getRelativeLocaleUrl } from "astro:i18n";
import { siteConfig } from "../../config/site.config";
import {
  getMessages,
  getOtherLocale,
  interpolate,
  resolveLocale,
} from "../../i18n";
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const locale = resolveLocale(Astro.currentLocale);
const otherLocale = getOtherLocale(locale);
const m = getMessages(locale);
const { cityCode, city, timezone } = siteConfig.location;

const pathWithoutLocale =
  locale === "en"
    ? Astro.url.pathname
    : Astro.url.pathname.replace(new RegExp(`^/${locale}`), "") || "/";

const otherLocaleHref = getRelativeLocaleUrl(otherLocale, pathWithoutLocale);
---

<div
  class:list={["theme-widget", className]}
  role="group"
  aria-label={m.themeWidget.ariaLabel}
  data-theme-widget
>
  <p
    class="theme-widget__chip theme-widget__location"
    data-live-clock
    data-timezone={timezone}
    aria-label={interpolate(m.themeWidget.locationAriaLabel, { city })}
  >
    <span class="theme-widget__location-sizer" aria-hidden="true"
      ><span>{cityCode}</span><span>·</span><span>00:00 pm</span></span
    >
    <span class="theme-widget__location-content"
      ><span class="theme-widget__city">{cityCode}</span
      ><span class="theme-widget__sep" aria-hidden="true">·</span
      ><span class="theme-widget__time" data-clock-time>--:--</span></span
    >
  </p>

  <a
    class="theme-widget__chip theme-widget__language"
    href={otherLocaleHref}
    data-feedback="tap hover"
    aria-label={interpolate(m.themeWidget.languageAriaLabel, { locale })}
  >
    {locale}
  </a>

  <button
    type="button"
    class="theme-widget__chip theme-widget__icon-btn"
    data-theme-widget-sound
    data-feedback="tap hover"
    aria-pressed="true"
    aria-label={m.themeWidget.soundOnAriaLabel}
  >
    <svg
      class="theme-widget__icon"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
    >
      <path
        d="M9 18V5L19 3V16"
        stroke="currentColor"
        stroke-width="1.3"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
      <circle
        cx="7"
        cy="18"
        r="2"
        stroke="currentColor"
        stroke-width="1.3"></circle>
      <circle
        cx="17"
        cy="16"
        r="2"
        stroke="currentColor"
        stroke-width="1.3"></circle>
    </svg>
  </button>

  <ThemeToggle class="theme-widget__theme" />
</div>

<style>
  .theme-widget {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    padding: var(--space-sm);
    border-radius: var(--radius-widget);
    background: var(--color-bg-surface);
  }

  .theme-widget__chip {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    height: var(--space-2xl);
    margin: 0;
    border: none;
    border-radius: var(--radius-control);
    background: var(--color-bg-control);
    color: var(--color-text-primary);
    font-family: var(--font-family);
    font-weight: var(--font-weight-regular);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-normal);
    text-decoration: none;
    white-space: nowrap;
    cursor: default;
  }

  .theme-widget__location {
    display: inline-grid;
    justify-items: start;
    align-items: center;
    padding: var(--space-control) var(--space-md);
  }

  .theme-widget__location-sizer,
  .theme-widget__location-content {
    grid-area: 1 / 1;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    min-width: 0;
  }

  .theme-widget__location-sizer {
    visibility: hidden;
    pointer-events: none;
    user-select: none;
  }

  .theme-widget__location-sizer > :last-child,
  .theme-widget__time {
    font-variant-numeric: tabular-nums;
    text-align: left;
  }

  .theme-widget__language,
  .theme-widget__icon-btn {
    cursor: pointer;
    transition: color var(--motion-base) var(--ease-out-expo);
  }

  .theme-widget__language {
    width: var(--space-2xl);
    padding: var(--space-control) 0;
    font-variant-numeric: tabular-nums;
  }

  .theme-widget__icon-btn {
    padding: var(--space-control);
  }

  .theme-widget__language:hover,
  .theme-widget__icon-btn:hover {
    color: var(--color-link-hover);
  }

  .theme-widget__icon-btn[data-sound-muted] {
    opacity: 0.45;
  }

  .theme-widget__icon {
    display: block;
    width: var(--space-lg);
    height: var(--space-lg);
  }

  .theme-widget :global(.theme-toggle__host.theme-widget__theme),
  .theme-widget :global(.theme-widget__theme) {
    flex-shrink: 0;
  }

  .theme-widget :global(.theme-toggle) {
    width: var(--space-2xl);
    height: var(--space-2xl);
  }

  @media (prefers-reduced-motion: reduce) {
    .theme-widget__language,
    .theme-widget__icon-btn {
      transition: none;
    }
  }
</style>

<script>
  import { initThemeWidget } from "./themeWidget.client";

  initThemeWidget();
  document.addEventListener("astro:page-load", () => initThemeWidget());
</script>
