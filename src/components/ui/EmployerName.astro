---
import "./employer-name.css";
import { siteConfig } from "../../config/site.config";
import { getMessages, interpolate } from "../../i18n";

interface Props {
  label: string;
}

const { label } = Astro.props;
const { video: videoSrc, url: employerUrl } = siteConfig.employer;
const m = getMessages();
---

<span
  class="employer-name"
  data-employer-name-host
  data-employer-video={videoSrc}
  data-wash-tint="employer"
>
  <a
    class="employer-name__link"
    href={employerUrl}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={interpolate(m.header.employerAriaLabel, { employer: label })}
  >
    <span class="employer-name__label">{label}.</span>
  </a>
</span>
