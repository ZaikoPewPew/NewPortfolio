---
import { getMessages, resolveLocale } from "../../i18n";
import Tooltip from "./Tooltip.astro";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const m = getMessages(resolveLocale(Astro.currentLocale));
const themeNames = m.theme.names;
---

<div
  class:list={["theme-toggle__host", className]}
  data-tooltip-host
  data-theme-toggle-host
  data-next-theme="violet"
  data-theme-names={JSON.stringify(themeNames)}
>
  <button
    type="button"
    class="theme-toggle"
    aria-label={m.theme.toggleAriaLabel}
    data-theme-toggle
    data-feedback="tap hover"
  >
    <svg
      class="theme-toggle__icon"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
    >
      <path
        class="theme-toggle__stroke theme-toggle__stroke--outline"
        d="M20 21V6C20 4.89543 19.1046 4 18 4H6C4.89543 4 4 4.89543 4 6V21L6 20L8 21L10 20L12 21L14 20L16 21L18 20L20 21Z"
        stroke-width="1.3"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
      <path
        class="theme-toggle__stroke theme-toggle__stroke--line-1"
        d="M8 8H16"
        stroke-width="1.3"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
      <path
        class="theme-toggle__stroke theme-toggle__stroke--line-2"
        d="M8 12H16"
        stroke-width="1.3"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
      <path
        class="theme-toggle__stroke theme-toggle__stroke--line-3"
        d="M8 16H14"
        stroke-width="1.3"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </button>
  <Tooltip class="theme-toggle__tooltip" placement="bottom" lines={[themeNames.chocolate]} keycap="t" />
</div>

<style>
  .theme-toggle__host {
    position: relative;
    display: inline-flex;
  }

  .theme-toggle__host[data-next-theme="chocolate"] {
    --color-theme-preview-1: var(--theme-swatch-chocolate-1);
    --color-theme-preview-2: var(--theme-swatch-chocolate-2);
    --color-theme-preview-3: var(--theme-swatch-chocolate-3);
  }

  .theme-toggle__host[data-next-theme="violet"] {
    --color-theme-preview-1: var(--theme-swatch-violet-1);
    --color-theme-preview-2: var(--theme-swatch-violet-2);
    --color-theme-preview-3: var(--theme-swatch-violet-3);
  }

  .theme-toggle__host[data-next-theme="clay"] {
    --color-theme-preview-1: var(--theme-swatch-clay-1);
    --color-theme-preview-2: var(--theme-swatch-clay-2);
    --color-theme-preview-3: var(--theme-swatch-clay-3);
  }

  .theme-toggle__host[data-next-theme="amber"] {
    --color-theme-preview-1: var(--theme-swatch-amber-1);
    --color-theme-preview-2: var(--theme-swatch-amber-2);
    --color-theme-preview-3: var(--theme-swatch-amber-3);
  }

  .theme-toggle__host[data-next-theme="merlot"] {
    --color-theme-preview-1: var(--theme-swatch-merlot-1);
    --color-theme-preview-2: var(--theme-swatch-merlot-2);
    --color-theme-preview-3: var(--theme-swatch-merlot-3);
  }

  .theme-toggle__host[data-next-theme="sage"] {
    --color-theme-preview-1: var(--theme-swatch-sage-1);
    --color-theme-preview-2: var(--theme-swatch-sage-2);
    --color-theme-preview-3: var(--theme-swatch-sage-3);
  }

  .theme-toggle__host[data-next-theme="graphite"] {
    --color-theme-preview-1: var(--theme-swatch-graphite-1);
    --color-theme-preview-2: var(--theme-swatch-graphite-2);
    --color-theme-preview-3: var(--theme-swatch-graphite-3);
  }

  .theme-toggle__host[data-next-theme="light"] {
    --color-theme-preview-1: var(--theme-swatch-light-1);
    --color-theme-preview-2: var(--theme-swatch-light-2);
    --color-theme-preview-3: var(--theme-swatch-light-3);
  }

  .theme-toggle__host :global(.theme-toggle__tooltip) {
    top: calc(100% + var(--tooltip-offset));
    bottom: auto;
  }

  .theme-toggle {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    width: var(--space-2xl);
    height: var(--space-2xl);
    padding: var(--space-control);
    border: none;
    border-radius: var(--radius-control);
    background: var(--color-bg-control);
    color: var(--color-text-primary);
    cursor: pointer;
  }

  .theme-toggle__icon {
    width: var(--space-lg);
    height: var(--space-lg);
    transform-origin: center;
    transition: transform var(--motion-theme-toggle) var(--ease-theme-toggle);
  }

  .theme-toggle__stroke {
    stroke: currentColor;
    transition: stroke var(--motion-theme-toggle) var(--ease-theme-toggle);
  }

  .theme-toggle:hover .theme-toggle__icon {
    transform: translateY(calc(var(--theme-toggle-hover-lift) * -1))
      rotate(var(--theme-toggle-hover-rotate));
  }

  .theme-toggle:hover .theme-toggle__stroke--line-1 {
    stroke: var(--color-theme-preview-1);
  }

  .theme-toggle:hover .theme-toggle__stroke--line-2 {
    stroke: var(--color-theme-preview-2);
  }

  .theme-toggle:hover .theme-toggle__stroke--line-3 {
    stroke: var(--color-theme-preview-3);
  }

  @media (prefers-reduced-motion: reduce) {
    .theme-toggle__icon,
    .theme-toggle__stroke {
      transition: none;
    }

    .theme-toggle:hover .theme-toggle__icon {
      transform: none;
    }
  }
</style>

<script>
  import { toggleThemeWithTransition } from "../../experience/preferences/themeTransition";
  import { getNextTheme, userPreferences } from "../../experience/preferences/UserPreferences";
  import { initDragTooltips } from "./tooltip.client";

  let themeSyncSubscribed = false;

  type ThemeNamesMap = Record<string, string>;

  function readThemeNames(host: Element): ThemeNamesMap {
    const raw = host.getAttribute("data-theme-names");
    if (!raw) return {};

    try {
      const parsed = JSON.parse(raw) as unknown;
      if (!parsed || typeof parsed !== "object") return {};
      return parsed as ThemeNamesMap;
    } catch {
      return {};
    }
  }

  function updateThemeToggleTooltip(root: ParentNode = document) {
    const hosts: Element[] = [];
    if (root instanceof Element && root.matches("[data-theme-toggle-host]")) {
      hosts.push(root);
    }
    root.querySelectorAll("[data-theme-toggle-host]").forEach((host) => hosts.push(host));

    hosts.forEach((host) => {
      const currentTheme = userPreferences.get().theme;
      const nextTheme = getNextTheme(currentTheme);
      host.setAttribute("data-next-theme", nextTheme);

      const line = host.querySelector<HTMLElement>(".theme-toggle__tooltip .tooltip__line");
      if (!line) return;

      const themeNames = readThemeNames(host);
      line.textContent = themeNames[nextTheme] ?? nextTheme;
    });
  }

  function bindThemeToggle(root: ParentNode = document) {
    root.querySelectorAll("[data-theme-toggle]").forEach((btn) => {
      if (btn.hasAttribute("data-bound")) return;
      btn.setAttribute("data-bound", "true");
      btn.addEventListener("click", (e) => {
        const target = e.currentTarget as HTMLElement;
        const host = target.closest<HTMLElement>("[data-theme-toggle-host]");
        if (host) {
          host.removeAttribute("data-tooltip-visible");
          host.setAttribute("data-tooltip-dismissed", "");
        }

        const rect = target.getBoundingClientRect();
        toggleThemeWithTransition({
          x: rect.left + rect.width / 2,
          y: rect.top + rect.height / 2,
        });

        if (host) updateThemeToggleTooltip(host);
      });
    });
  }

  bindThemeToggle();
  initDragTooltips();
  updateThemeToggleTooltip();

  /* Reflect theme state from any source (click, hotkey `t`). */
  if (!themeSyncSubscribed) {
    themeSyncSubscribed = true;
    userPreferences.subscribe(() => updateThemeToggleTooltip());
  }

  document.addEventListener("astro:page-load", () => bindThemeToggle());
  document.addEventListener("astro:page-load", () => initDragTooltips());
  document.addEventListener("astro:page-load", () => updateThemeToggleTooltip());
</script>
