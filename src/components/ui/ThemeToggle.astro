---
import { getMessages, resolveLocale } from "../../i18n";
import Tooltip from "./Tooltip.astro";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const m = getMessages(resolveLocale(Astro.currentLocale));
const themeNames = m.theme.names;
---

<div
  class:list={["theme-toggle__host", className]}
  data-tooltip-host
  data-theme-toggle-host
  data-theme-names={JSON.stringify(themeNames)}
>
  <button
    type="button"
    class="theme-toggle"
    aria-label={m.theme.toggleAriaLabel}
    data-theme-toggle
    data-feedback="tap hover"
  >
    <svg
      class="theme-toggle__icon"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
    >
      <path
        d="M9 16V17C9 18.6569 10.3431 20 12 20C13.6569 20 15 18.6569 15 17V16M9 16H5.48604C4.66532 16 4 15.3347 4 14.514C4 14.181 4.11182 13.8577 4.31754 13.5959L8.59915 8.14653C9.16791 7.42266 10.0375 7 10.9581 7H12M9 16H15M15 16H18.514C19.3347 16 20 15.3347 20 14.514C20 14.181 19.8882 13.8577 19.6825 13.5959L15.4008 8.14654C14.8321 7.42266 13.9625 7 13.0419 7H12M12 7V4"
        stroke="currentColor"
        stroke-width="1.3"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </button>
  <Tooltip class="theme-toggle__tooltip" placement="bottom" lines={[themeNames.dark]} />
</div>

<style>
  .theme-toggle__host {
    position: relative;
    display: inline-flex;
  }

  .theme-toggle__host :global(.theme-toggle__tooltip) {
    top: calc(100% + var(--tooltip-offset));
    bottom: auto;
  }

  .theme-toggle {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    width: var(--space-2xl);
    height: var(--space-2xl);
    padding: var(--space-control);
    border: none;
    border-radius: var(--radius-control);
    background: var(--color-bg-control);
    color: var(--color-text-primary);
    cursor: pointer;
    transition: color var(--motion-base) var(--ease-out-expo);
  }

  .theme-toggle:hover {
    color: var(--color-link-hover);
  }

  .theme-toggle__icon {
    width: var(--space-lg);
    height: var(--space-lg);
  }

  @media (prefers-reduced-motion: reduce) {
    .theme-toggle {
      transition: none;
    }
  }
</style>

<script>
  import { toggleThemeWithTransition } from "../../experience/preferences/themeTransition";
  import { getNextTheme, userPreferences } from "../../experience/preferences/UserPreferences";
  import { initDragTooltips } from "./tooltip.client";

  type ThemeNamesMap = Record<string, string>;

  function readThemeNames(host: Element): ThemeNamesMap {
    const raw = host.getAttribute("data-theme-names");
    if (!raw) return {};

    try {
      const parsed = JSON.parse(raw) as unknown;
      if (!parsed || typeof parsed !== "object") return {};
      return parsed as ThemeNamesMap;
    } catch {
      return {};
    }
  }

  function updateThemeToggleTooltip(root: ParentNode = document) {
    const hosts: Element[] = [];
    if (root instanceof Element && root.matches("[data-theme-toggle-host]")) {
      hosts.push(root);
    }
    root.querySelectorAll("[data-theme-toggle-host]").forEach((host) => hosts.push(host));

    hosts.forEach((host) => {
      const line = host.querySelector<HTMLElement>(".theme-toggle__tooltip .tooltip__line");
      if (!line) return;

      const currentTheme = userPreferences.get().theme;
      const nextTheme = getNextTheme(currentTheme);
      const themeNames = readThemeNames(host);
      line.textContent = themeNames[nextTheme] ?? nextTheme;
    });
  }

  function bindThemeToggle(root: ParentNode = document) {
    root.querySelectorAll("[data-theme-toggle]").forEach((btn) => {
      if (btn.hasAttribute("data-bound")) return;
      btn.setAttribute("data-bound", "true");
      btn.addEventListener("click", (e) => {
        const target = e.currentTarget as HTMLElement;
        const host = target.closest<HTMLElement>("[data-theme-toggle-host]");
        if (host) {
          host.removeAttribute("data-tooltip-visible");
          host.setAttribute("data-tooltip-dismissed", "");
        }

        const rect = target.getBoundingClientRect();
        toggleThemeWithTransition({
          x: rect.left + rect.width / 2,
          y: rect.top + rect.height / 2,
        });

        if (host) updateThemeToggleTooltip(host);
      });
    });
  }

  bindThemeToggle();
  initDragTooltips();
  updateThemeToggleTooltip();
  document.addEventListener("astro:page-load", () => bindThemeToggle());
  document.addEventListener("astro:page-load", () => initDragTooltips());
  document.addEventListener("astro:page-load", () => updateThemeToggleTooltip());
</script>
