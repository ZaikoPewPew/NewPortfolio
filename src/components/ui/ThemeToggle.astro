---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<button
  type="button"
  class:list={["theme-toggle", className]}
  aria-label="Сменить тему"
  data-theme-toggle
  data-feedback="tap"
>
  <svg
    class="theme-toggle__icon"
    width="24"
    height="24"
    viewBox="0 0 24 24"
    fill="none"
    aria-hidden="true"
  >
    <path
      d="M5 12H3M12 5V3M21 12H19M12 21V19M16.9496 16.9498L18.3638 18.364M5.63602 5.63608L7.05023 7.05029M16.9496 7.0502L18.3638 5.63599M5.63602 18.3639L7.05023 16.9497M15 12C15 13.6569 13.6569 15 12 15C10.3431 15 9 13.6569 9 12C9 10.3431 10.3431 9 12 9C13.6569 9 15 10.3431 15 12Z"
      stroke="currentColor"
      stroke-width="1.3"
      stroke-linecap="round"
      stroke-linejoin="round"></path>
  </svg>
</button>

<style>
  .theme-toggle {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    width: var(--space-2xl);
    height: var(--space-2xl);
    padding: var(--space-control);
    border: none;
    border-radius: var(--radius-control);
    background: var(--color-bg-control);
    color: var(--color-text-primary);
    cursor: pointer;
    transition: transform var(--motion-fast) var(--ease-out-expo);
  }

  .theme-toggle:hover {
    transform: scale(1.04);
  }

  .theme-toggle__icon {
    width: var(--space-lg);
    height: var(--space-lg);
  }

  @media (prefers-reduced-motion: reduce) {
    .theme-toggle {
      transition: none;
    }
  }
</style>

<script>
  import { toggleThemeWithTransition } from "../../experience/preferences/themeTransition";

  function bindThemeToggle(root: ParentNode = document) {
    root.querySelectorAll("[data-theme-toggle]").forEach((btn) => {
      if (btn.hasAttribute("data-bound")) return;
      btn.setAttribute("data-bound", "true");
      btn.addEventListener("click", (e) => {
        const target = e.currentTarget as HTMLElement;
        const rect = target.getBoundingClientRect();
        toggleThemeWithTransition({
          x: rect.left + rect.width / 2,
          y: rect.top + rect.height / 2,
        });
      });
    });
  }

  bindThemeToggle();
  document.addEventListener("astro:page-load", () => bindThemeToggle());
</script>
