---
import { siteConfig } from "../../config/site.config";
import { getMessages, interpolate, resolveLocale } from "../../i18n";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const locale = resolveLocale(Astro.currentLocale);
const m = getMessages(locale);
const { city, timezone } = siteConfig.location;
---

<p
  class:list={["live-clock", className]}
  data-live-clock
  data-timezone={timezone}
  aria-label={interpolate(m.liveClock.ariaLabel, { city })}
>
  <span class="live-clock__city">{city}</span>
  <span class="live-clock__time" data-clock-time>--:--</span>
</p>

<script>
  import { initLiveClock } from "./liveClock.client";

  initLiveClock();
  document.addEventListener("astro:page-load", () => initLiveClock());
</script>

<style>
  .live-clock {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin: 0;
    font-family: var(--font-family);
    font-weight: var(--font-weight-regular);
    font-size: var(--font-size-base);
    line-height: var(--line-height-normal);
    text-align: left;
    white-space: nowrap;
  }

  .live-clock__city {
    color: var(--color-text-primary);
  }

  .live-clock__time {
    color: var(--color-text-subdued);
    font-variant-numeric: tabular-nums;
  }
</style>
