---
import { siteConfig } from "../../config/site.config";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const { city, timezone } = siteConfig.location;
---

<p
  class:list={["live-clock", className]}
  data-live-clock
  data-timezone={timezone}
>
  <span class="live-clock__city">{city}</span>
  <span class="live-clock__time" data-clock-time>--:--</span>
</p>

<script>
  import { initLiveClock } from "./liveClock.client";

  initLiveClock();
  document.addEventListener("astro:page-load", () => initLiveClock());
</script>

<style>
  .live-clock {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    margin: 0;
    font-family: var(--font-family);
    font-weight: var(--font-weight-regular);
    font-size: var(--font-size-base);
    line-height: var(--line-height-normal);
    text-align: right;
    white-space: nowrap;
  }

  .live-clock__city {
    color: var(--color-text-primary);
  }

  .live-clock__time {
    color: var(--color-text-subdued);
  }

  @media (max-width: 639px) {
    .live-clock {
      flex-direction: row;
      align-items: center;
    }

    .live-clock__city {
      display: none;
    }

    .live-clock__time {
      font-size: var(--header-employer-size-mobile);
      line-height: var(--line-height-normal);
    }
  }
</style>
