---
import { siteConfig } from "../../config/site.config";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const { city, timezone } = siteConfig.location;
---

<p class:list={["live-clock", className]} data-live-clock>
  <span class="live-clock__city">{city}</span>
  <span class="live-clock__time" data-clock-time>--:--</span>
</p>

<script define:vars={{ timezone }}>
  function bindLiveClock(root: ParentNode = document) {
    root.querySelectorAll("[data-live-clock]").forEach((clock) => {
      if (clock.hasAttribute("data-clock-bound")) return;
      clock.setAttribute("data-clock-bound", "true");

      const timeEl = clock.querySelector("[data-clock-time]");
      if (!timeEl) return;

      function update() {
        timeEl.textContent = new Intl.DateTimeFormat("en-US", {
          timeZone: timezone,
          hour: "numeric",
          minute: "2-digit",
          hour12: true,
        }).format(new Date());
      }

      update();
      setInterval(update, 60_000);
    });
  }

  bindLiveClock();
  document.addEventListener("astro:page-load", () => bindLiveClock());
</script>

<style>
  .live-clock {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    margin: 0;
    font-family: var(--font-family);
    font-weight: var(--font-weight-regular);
    font-size: var(--font-size-base);
    line-height: var(--line-height-normal);
    text-align: right;
    white-space: nowrap;
  }

  .live-clock__city {
    color: var(--color-text-primary);
  }

  .live-clock__time {
    color: var(--color-text-subdued);
  }

  @media (max-width: 639px) {
    .live-clock {
      flex-direction: row;
      align-items: center;
    }

    .live-clock__city {
      display: none;
    }

    .live-clock__time {
      font-size: var(--header-employer-size-mobile);
      line-height: var(--line-height-normal);
    }
  }
</style>
