---
import type { CollectionEntry } from "astro:content";
import Tag from "../ui/Tag.astro";
import { casesConfig } from "../../config/cases.config";
import { siteConfig } from "../../config/site.config";
import { getCaseTitle } from "../../features/cases/getCaseTitle";

interface Props {
  caseEntry: CollectionEntry<"cases">;
}

const { caseEntry } = Astro.props;
const { tags, hover, card } = caseEntry.data;
const slug = caseEntry.slug;
const title = getCaseTitle(slug);
const logo = card?.logo ?? casesConfig.cardLogoPlaceholder;
---

<a
  href={`/cases/${slug}`}
  class="case-card"
  data-case-card
  data-case-nav
  data-case-slug={slug}
  data-hover-from={hover.gradientFrom}
  data-hover-to={hover.gradientTo}
  data-hover-angle={hover.gradientAngle}
  data-hover-video={hover.previewVideo ?? siteConfig.employer.video}
  tabindex="0"
>
  <article
    class="case-card__inner"
    data-case-list-shell
    transition:name={`case-list-${slug}`}
  >
    <div class="case-card__morph" data-case-morph transition:name={`case-${slug}`}></div>

    <div class="case-card__content">
      <div class="case-card__tags">
        {tags.map((tag, index) => (
          <span class="case-card__tag" style={`--case-tag-index: ${index}`}>
            <Tag label={tag} variant="pill" />
          </span>
        ))}
      </div>

      <div class="case-card__footer">
        <img
          class="case-card__logo"
          src={logo}
          alt=""
          loading="lazy"
          decoding="async"
        />
        <p class="case-card__title">{title}</p>
      </div>
    </div>
  </article>
</a>

<style>
  .case-card {
    display: block;
    width: 100%;
    max-width: var(--case-card-width);
    height: var(--case-card-height);
    text-decoration: none;
    color: inherit;
  }

  .case-card:focus-visible {
    outline: none;
  }

  .case-card:focus-visible .case-card__inner {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .case-card__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
    padding: var(--space-sm);
    border-radius: var(--radius-widget);
    background: var(--color-bg-surface);
    overflow: hidden;
    transition:
      transform var(--motion-base) var(--ease-out-expo),
      box-shadow var(--motion-base) var(--ease-out-expo);
  }

  .case-card__morph {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: var(--color-bg-surface);
    z-index: 0;
  }

  .case-card__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: space-between;
    flex: 1;
    min-height: 0;
    pointer-events: none;
  }

  .case-card__tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: var(--space-xs);
  }

  .case-card__tag {
    display: inline-flex;
    opacity: 0;
    transform: translate3d(var(--case-tag-enter-offset), calc(-1 * var(--case-tag-enter-offset)), 0)
      scale(0.88);
    transition:
      opacity var(--motion-fast) var(--ease-out-expo),
      transform var(--motion-fast) var(--ease-out-expo);
    transition-delay: 0ms;
  }

  .case-card.is-active .case-card__tag,
  .case-card:focus-visible .case-card__tag {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
    transition-duration: var(--motion-case-tag-duration);
    transition-timing-function: var(--ease-spring-snappy);
    transition-delay: calc(var(--case-tag-index, 0) * var(--motion-case-tag-stagger));
  }

  .case-card__footer {
    display: flex;
    align-items: center;
    gap: var(--space-control);
    width: 100%;
    min-width: 0;
  }

  .case-card__logo {
    flex-shrink: 0;
    width: var(--case-card-logo-size);
    height: var(--case-card-logo-size);
    border-radius: var(--radius-control);
    object-fit: cover;
  }

  .case-card__title {
    margin: 0;
    flex: 1;
    min-width: 0;
    font-family: var(--font-family);
    font-weight: var(--font-weight-regular);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-normal);
    color: var(--color-text-primary);
    overflow-wrap: anywhere;
  }

  @media (prefers-reduced-motion: reduce) {
    .case-card__inner,
    .case-card__tag {
      transition: none;
    }

    .case-card.is-active .case-card__tag,
    .case-card:focus-visible .case-card__tag {
      opacity: 1;
      transform: none;
    }
  }
</style>
