---
import type { CollectionEntry } from "astro:content";

interface Props {
  caseEntry: CollectionEntry<"cases">;
}

const { caseEntry } = Astro.props;
const { title, summary, year, cover, card } = caseEntry.data;
const slug = caseEntry.slug;
const layout = card?.layout ?? "horizontal";
const subtitle = card?.subtitle;
---

<a
  href={`/cases/${slug}`}
  class:list={["case-card", `case-card--${layout}`]}
  data-case-card
  data-case-nav
  data-case-slug={slug}
  tabindex="0"
>
  <article
    class="case-card__inner"
    data-case-list-shell
    transition:name={`case-list-${slug}`}
  >
    <div class="case-card__morph" data-case-morph transition:name={`case-${slug}`}>
      <div class="case-card__media">
        <img class="case-card__cover" src={cover} alt="" loading="lazy" decoding="async" />
      </div>
      <h2 class="case-card__title">{title}</h2>
    </div>
    <div class="case-card__body">
      {subtitle && <p class="case-card__subtitle">{subtitle}</p>}
      <p class="case-card__summary">{summary}</p>
      <span class="case-card__year">{year}</span>
    </div>
  </article>
</a>

<style>
  .case-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: var(--radius-widget);
    background: var(--color-bg-surface);
    overflow: hidden;
    transition:
      transform var(--motion-base) var(--ease-out-expo),
      box-shadow var(--motion-base) var(--ease-out-expo);
  }

  .case-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .case-card__inner {
    display: flex;
    min-height: var(--case-card-min-height);
  }

  .case-card--horizontal .case-card__inner {
    flex-direction: row;
  }

  .case-card--compact .case-card__inner {
    flex-direction: column;
  }

  .case-card__morph {
    display: flex;
    min-width: 0;
    flex-shrink: 0;
  }

  .case-card--horizontal .case-card__morph {
    flex-direction: row;
    align-items: stretch;
  }

  .case-card--compact .case-card__morph {
    flex-direction: column;
    width: 100%;
  }

  .case-card__media {
    flex-shrink: 0;
    overflow: hidden;
    background: var(--color-bg-elevated);
  }

  .case-card--horizontal .case-card__media {
    width: var(--case-card-media-width);
  }

  .case-card--compact .case-card__media {
    aspect-ratio: 16 / 10;
    width: 100%;
  }

  .case-card__cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .case-card__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-sm);
    padding: var(--space-lg);
    min-width: 0;
  }

  .case-card--compact .case-card__title {
    padding: var(--space-lg);
    padding-top: var(--space-md);
  }

  .case-card--horizontal .case-card__title {
    display: flex;
    flex: 1;
    align-items: center;
    padding: var(--space-lg);
    padding-left: 0;
    min-width: 0;
  }

  .case-card__subtitle {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }

  .case-card__title {
    font-size: var(--font-size-xl);
    line-height: var(--line-height-tight);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-primary);
  }

  .case-card__summary {
    font-size: var(--font-size-base);
    line-height: var(--line-height-normal);
    color: var(--color-text-muted);
  }

  .case-card__year {
    margin-top: var(--space-xs);
    font-size: var(--font-size-sm);
    color: var(--color-text-subdued);
  }

  @media (max-width: 639px) {
    .case-card--horizontal .case-card__inner {
      flex-direction: column;
    }

    .case-card--horizontal .case-card__media {
      width: 100%;
      aspect-ratio: 16 / 10;
    }
  }
</style>
