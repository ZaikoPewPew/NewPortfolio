---
import type { CollectionEntry } from "astro:content";
import {
  groupHomeCasesByCompany,
} from "../../features/home/cases/getHomeCases";
import "../../features/home/case-hover/case-focus.css";
import CaseCompany from "./CaseCompany.astro";

interface Props {
  cases: CollectionEntry<"cases">[];
}

const { cases } = Astro.props;
const groups = groupHomeCasesByCompany(cases);
---

<div class="case-list">
  {groups.map((group, index) => <CaseCompany group={group} index={index} />)}
</div>

<style>
  .case-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-cases-company-gap);
    width: 100%;
    max-width: 100%;
  }
</style>
