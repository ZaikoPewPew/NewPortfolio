---
import type { CollectionEntry } from "astro:content";
import CaseCard from "./CaseCard.astro";

interface Props {
  cases: CollectionEntry<"cases">[];
}

const { cases } = Astro.props;

const viewTransitionRules = cases
  .map((caseEntry) => {
    const slug = caseEntry.slug;
    return `
::view-transition-old(case-list-${slug}) {
  animation: caseCollapseOut var(--motion-case-collapse) var(--ease-case-exit) both;
  transform-origin: top center;
}

::view-transition-group(case-${slug}) {
  animation-duration: var(--motion-case-morph);
  animation-timing-function: var(--ease-case-enter);
}

::view-transition-old(case-${slug}) {
  animation: caseMorphOldFade var(--motion-case-morph) var(--ease-case-exit) both;
  overflow: hidden;
  border-radius: var(--radius-widget);
}

::view-transition-new(case-${slug}) {
  animation: caseMorphNewFade var(--motion-case-morph) var(--ease-case-enter) both;
  overflow: hidden;
  border-radius: var(--radius-card);
}

html.is-case-returning ::view-transition-group(case-${slug}),
html.is-case-returning ::view-transition-old(case-${slug}),
html.is-case-returning ::view-transition-new(case-${slug}) {
  animation-duration: var(--motion-case-back);
  animation-timing-function: var(--ease-case-exit);
}`;
  })
  .join("\n");

const reducedMotionRules = cases
  .map(
    (caseEntry) => `
::view-transition-old(case-list-${caseEntry.slug}),
::view-transition-old(case-${caseEntry.slug}),
::view-transition-new(case-${caseEntry.slug}) {
  animation: none !important;
}`
  )
  .join("\n");

const globalCaseTransitionCss = `@media (min-width: 640px) {
${viewTransitionRules}
}

@media (min-width: 640px) and (prefers-reduced-motion: reduce) {
${reducedMotionRules}
}`;
---

<ul class="case-list">
  {
    cases.map((caseEntry) => (
      <li class="case-list__item">
        <CaseCard caseEntry={caseEntry} />
      </li>
    ))
  }
</ul>

<style is:global set:html={globalCaseTransitionCss}></style>

<style>
  .case-list {
    display: flex;
    flex-direction: column;
    gap: var(--layout-column-gap);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .case-list__item {
    min-width: 0;
  }
</style>
