---
import type { HomeCaseCompanyGroup } from "../../features/home/cases/getHomeCases";
import { resolveCompanyHoverMedia } from "../../features/cases/resolveCompanyHoverMedia";
import CaseRow from "./CaseRow.astro";

interface Props {
  group: HomeCaseCompanyGroup;
  index: number;
}

const { group, index } = Astro.props;
const media = resolveCompanyHoverMedia(group.company, group.companyVideo, group.companyImage);
const hoverAttrs = {
  ...(media.hoverVideo ? { "data-hover-video": media.hoverVideo } : {}),
  ...(media.hoverImage ? { "data-hover-image": media.hoverImage } : {}),
};
---

<section
  class="case-company"
  data-case-company
  data-page-enter
  style={`--page-enter-delay: calc(var(--page-enter-cases-base-active) + ${index} * var(--page-enter-delay-cases-step))`}
>
  <div class="case-company__name">
    <a
      class="case-company__link"
      href={group.companyUrl}
      target="_blank"
      rel="noopener noreferrer"
      data-case-company-link
      {...(group.companyWash ? { "data-wash-color": group.companyWash } : {})}
      {...hoverAttrs}
    >
      <span class="case-company__label">{group.company}</span>
      <svg
        class="case-company__icon"
        width="18"
        height="18"
        viewBox="0 0 18 18"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <path
          d="M5.28769 12.7125L12.7123 5.28787M12.7123 11.6518V5.28787H6.34835"
          stroke="currentColor"
          stroke-width="1.3"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </a>
  </div>

  <div class="case-company__cases">
    {group.cases.map((caseEntry) => <CaseRow caseEntry={caseEntry} />)}
  </div>
</section>

<style>
  /*
   * [142 company | fluid case rows]
   * Inside each row: [fluid title | 142 year]
   * Gaps 16px → company left-aligned, years right-aligned in .home__cases.
   */
  .case-company {
    position: relative;
    display: grid;
    grid-template-columns: var(--case-company-name-width) minmax(0, 1fr);
    column-gap: var(--layout-column-gap);
    align-items: start;
    width: 100%;
    min-width: 0;
  }

  .case-company.is-focused {
    z-index: var(--z-employer-focus);
  }

  .case-company__name {
    min-width: 0;
  }

  .case-company__link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    width: fit-content;
    max-width: 100%;
    font-family: var(--font-family);
    font-weight: var(--case-company-font-weight);
    font-size: var(--case-list-font-size);
    line-height: var(--line-height-normal);
    color: var(--color-text-primary);
    text-decoration: none;
    background-image: linear-gradient(currentColor, currentColor);
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 0% 1px;
    transition: background-size var(--motion-fast) var(--ease-out-expo);
  }

  .case-company__link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: var(--space-2xs);
  }

  .case-company__icon {
    flex-shrink: 0;
    width: var(--case-company-icon-size);
    height: var(--case-company-icon-size);
    opacity: 0;
    transform: translate3d(calc(-1 * var(--space-xs)), var(--space-xs), 0);
    transition:
      opacity var(--motion-fast) var(--ease-out-expo),
      transform var(--motion-fast) var(--ease-out-expo);
  }

  .case-company__link:hover,
  .case-company__link:focus-visible {
    background-size: 100% 1px;
  }

  .case-company__link:hover .case-company__icon,
  .case-company__link:focus-visible .case-company__icon {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .case-company__cases {
    display: flex;
    flex-direction: column;
    gap: var(--layout-column-gap);
    min-width: 0;
  }

  @media (max-width: 639px) {
    .case-company {
      grid-template-columns: 1fr;
      row-gap: var(--space-sm);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .case-company__link,
    .case-company__icon {
      transition: none;
    }

    .case-company__link:hover .case-company__icon,
    .case-company__link:focus-visible .case-company__icon {
      transform: none;
    }
  }
</style>
