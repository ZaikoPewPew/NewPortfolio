---
import "./case-media.css";
import { withBase } from "../../../lib/withBase";

interface Props {
  src: string;
  poster?: string;
  caption?: string;
  width?: "content" | "full";
}

const { src, poster, caption, width = "content" } = Astro.props;
const videoSrc = withBase(src);
const posterSrc = poster ? withBase(poster) : undefined;
---

<figure class:list={["case-media", `case-media--${width}`]}>
  <video
    class="case-media__media"
    src={videoSrc}
    poster={posterSrc}
    controls
    playsinline
    preload="metadata"
  >
  </video>
  {caption && <figcaption class="case-media__caption">{caption}</figcaption>}
</figure>
