---
import "./case-media.css";

interface Props {
  src: string;
  alt: string;
  caption?: string;
  width?: "content" | "full";
}

const { src, alt, caption, width = "content" } = Astro.props;
---

<figure class:list={["case-media", `case-media--${width}`]}>
  <img class="case-media__media" src={src} alt={alt} loading="lazy" decoding="async" />
  {caption && <figcaption class="case-media__caption">{caption}</figcaption>}
</figure>
