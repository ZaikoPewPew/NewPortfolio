---
import type { CollectionEntry } from "astro:content";
import Tag from "../ui/Tag.astro";
import { getCaseTitle } from "../../features/cases/getCaseTitle";
import { resolveLocale } from "../../i18n";

interface Props {
  caseEntry: CollectionEntry<"cases">;
}

const { caseEntry } = Astro.props;
const { year, tags, cover } = caseEntry.data;
const slug = caseEntry.slug;
const title = getCaseTitle(slug, resolveLocale(Astro.currentLocale));
---

<header class="case-hero">
  <div class="case-hero__morph" data-case-morph transition:name={`case-${slug}`}>
    <div class="case-hero__media">
      <img class="case-hero__cover" src={cover} alt="" decoding="async" />
    </div>
    <h1 class="case-hero__title">{title}</h1>
  </div>
  <div class="case-hero__meta">
    <span class="case-hero__year">{year}</span>
    {tags.map((tag) => <Tag label={tag} />)}
  </div>
</header>

<style>
  .case-hero__morph {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .case-hero__media {
    overflow: hidden;
    border-radius: var(--radius-card);
    background: var(--color-bg-elevated);
    aspect-ratio: 16 / 9;
    width: 100%;
  }

  .case-hero__cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .case-hero__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .case-hero__year {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }

  .case-hero__title {
    font-size: var(--font-size-2xl);
    line-height: var(--line-height-tight);
    font-weight: var(--font-weight-medium);
  }
</style>
