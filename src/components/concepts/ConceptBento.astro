---
import { conceptItems } from "../../features/home/concepts/concepts.mock";
import { getMessages, resolveLocale } from "../../i18n";

const m = getMessages(resolveLocale(Astro.currentLocale));
---

<section class="concept-tiles" aria-label={m.concepts.ariaLabel}>
  <ul class="concept-tiles__list">
    {
      conceptItems.map((item, index) => (
        <li
          class="concept-tiles__item"
          data-page-enter=""
          style={`--page-enter-delay: calc(var(--page-enter-delay-concepts-base-active) + ${index} * var(--page-enter-delay-concepts-step));`}
        >
          <div class="concept-tiles__surface" data-concept-id={item.id}></div>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .concept-tiles {
    width: 100%;
    min-width: 0;
  }

  .concept-tiles__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    list-style: none;
    margin: 0;
    padding: 0;
    width: 100%;
  }

  .concept-tiles__item {
    display: block;
    width: 100%;
    max-width: var(--concept-tile-size);
    aspect-ratio: 1;
    min-width: 0;
    border-radius: var(--radius-widget);
    background-color: var(--color-bg-surface);
    overflow: hidden;
  }

  .concept-tiles__surface {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: var(--radius-widget);
    background-color: var(--color-bg-surface);
  }
</style>
