---
import { conceptItems } from "../../features/home/concepts/concepts.mock";
import { getMessages, resolveLocale } from "../../i18n";

const m = getMessages(resolveLocale(Astro.currentLocale));

function getTileHeight(rowSpan: 1 | 2 | undefined): string {
  return rowSpan === 2 ? "var(--case-card-height)" : "var(--concept-row-height)";
}
---

<section class="concept-bento" aria-label={m.concepts.ariaLabel}>
  <ul class="concept-bento__grid">
    {
      conceptItems.map((item, index) => (
        <li
          class="concept-bento__item"
          data-page-enter=""
          style={`--page-enter-delay: calc(var(--page-enter-delay-concepts-base-active) + ${index} * var(--page-enter-delay-concepts-step)); --concept-col-span: ${item.colSpan ?? 1}; --concept-row-span: ${item.rowSpan ?? 1}; height: ${getTileHeight(item.rowSpan)};`}
        >
          <div class="concept-bento__surface"></div>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .concept-bento {
    width: 100%;
    min-width: 0;
    margin-top: var(--layout-column-gap);
  }

  .concept-bento__grid {
    display: flex;
    flex-direction: column;
    gap: var(--layout-column-gap);
    list-style: none;
    margin: 0;
    padding: 0;
    width: 100%;
  }

  .concept-bento__item {
    display: block;
    width: 100%;
    min-width: 0;
    border-radius: var(--radius-widget);
    background-color: var(--color-bg-surface);
    overflow: hidden;
  }

  .concept-bento__surface {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: var(--radius-widget);
    background-color: var(--color-bg-surface);
  }

  @media (min-width: 640px) {
    .concept-bento__grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-auto-rows: minmax(var(--concept-row-height), auto);
    }

    .concept-bento__item {
      grid-column: span var(--concept-col-span, 1);
      grid-row: span var(--concept-row-span, 1);
    }
  }
</style>
