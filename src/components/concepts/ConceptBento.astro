---
import ConceptWidget from "./ConceptWidget.astro";
import { conceptItems } from "../../features/home/concepts/concepts.mock";
import { casesConfig } from "../../config/cases.config";
import { getMessages } from "../../i18n";

const m = getMessages();
const caseCount = casesConfig.homeLimit ?? 4;
const conceptsBaseDelay = `calc(var(--page-enter-cases-base-active) + ${caseCount} * var(--page-enter-delay-cases-step))`;
---

<section class="concept-bento" aria-label={m.concepts.ariaLabel}>
  <ul class="concept-bento__grid">
    {
      conceptItems.map((item, index) => (
        <li
          class="concept-bento__item"
          style={`
            --concept-col-span: ${item.colSpan ?? 1};
            --concept-row-span: ${item.rowSpan ?? 1};
            --page-enter-delay: calc(${conceptsBaseDelay} + ${index} * var(--page-enter-delay-concepts-step));
          `}
          data-page-enter
        >
          <ConceptWidget media={item.media} />
        </li>
      ))
    }
  </ul>
</section>

<style>
  .concept-bento {
    width: 100%;
    min-width: 0;
    margin-top: var(--layout-column-gap);
  }

  .concept-bento__grid {
    display: flex;
    flex-direction: column;
    gap: var(--layout-column-gap);
    list-style: none;
    margin: 0;
    padding: 0;
    width: 100%;
  }

  .concept-bento__item {
    min-width: 0;
    min-height: 0;
  }

  @media (min-width: 640px) {
    .concept-bento__grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-auto-rows: minmax(var(--concept-row-height), auto);
      align-items: stretch;
    }

    .concept-bento__item {
      grid-column: span var(--concept-col-span, 1);
      grid-row: span var(--concept-row-span, 1);
    }
  }
</style>
