---
import type { ConceptMedia } from "../../features/home/concepts/concept.types";

interface Props {
  media: ConceptMedia;
  class?: string;
}

const { media, class: className } = Astro.props;
---

<article class:list={["concept-widget", className]}>
  <div class="concept-widget__inner">
    <div class="concept-widget__media">
      {
        media.type === "video" ? (
          <video
            class="concept-widget__asset"
            src={media.src}
            muted
            playsinline
            loop
            preload="metadata"
            aria-label={media.alt}
          />
        ) : (
          <img
            class="concept-widget__asset"
            src={media.src}
            alt={media.alt}
            loading="lazy"
            decoding="async"
          />
        )
      }
    </div>
  </div>
</article>

<style>
  .concept-widget {
    display: block;
    width: 100%;
    height: 100%;
    min-height: calc(
      var(--concept-row-height) * var(--concept-row-span, 1) +
        var(--layout-column-gap) * (var(--concept-row-span, 1) - 1)
    );
  }

  .concept-widget__inner {
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
    min-height: inherit;
    padding: var(--space-sm);
    border-radius: var(--radius-widget);
    background: var(--color-bg-surface);
    overflow: hidden;
  }

  .concept-widget__media {
    position: relative;
    flex: 1;
    min-height: 0;
    min-width: 0;
    border-radius: var(--radius-control);
    overflow: hidden;
    background: var(--color-bg-elevated);
  }

  .concept-widget__asset {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
</style>
