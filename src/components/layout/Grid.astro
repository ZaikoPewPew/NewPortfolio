<div class="grid">
  <aside class="grid__widgets">
    <slot name="widgets" />
  </aside>
  <section class="grid__cases" aria-label="Кейсы">
    <slot name="cases" />
  </section>
</div>

<style>
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--layout-column-gap);
    width: 100%;
    align-items: start;
  }

  @media (min-width: 640px) {
    .grid {
      grid-template-columns: var(--layout-widgets-width) minmax(0, 1fr);
    }
  }

  .grid__widgets {
    width: 100%;
    min-width: 0;
  }

  .grid__cases {
    width: 100%;
    min-width: 0;
  }
</style>
