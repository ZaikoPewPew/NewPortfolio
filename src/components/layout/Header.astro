---
import LiveClock from "../ui/LiveClock.astro";
import { siteConfig } from "../../config/site.config";
---

<header class="header">
  <div class="header__inner">
    <div class="header__row">
      <p class="header__employer">
        {siteConfig.employer.prefix}{" "}
        <span class="header__employer-name">{siteConfig.employer.label}.</span>
      </p>
      <LiveClock />
    </div>
    <div class="header__divider" aria-hidden="true"></div>
  </div>
</header>

<style>
  .header {
    width: 100%;
    background: var(--color-bg-page);
    padding-top: var(--header-padding-top-desktop);
  }

  .header__inner {
    width: 100%;
    max-width: var(--layout-content-width);
    margin-inline: auto;
    padding-inline: var(--layout-gutter-desktop);
  }

  .header__row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
    min-height: var(--header-row-height-desktop);
  }

  .header__employer {
    margin: 0;
    font-family: var(--font-family);
    font-weight: var(--font-weight-regular);
    font-size: var(--header-employer-size-desktop);
    line-height: var(--line-height-tight);
    color: var(--color-text-primary);
    white-space: nowrap;
  }

  .header__employer-name {
    color: var(--color-accent);
  }

  .header__divider {
    margin-top: var(--header-divider-gap);
    width: 100%;
    height: 0;
    border-top: 1px solid var(--color-border-subtle);
  }

  @media (max-width: 639px) {
    .header {
      padding-top: var(--header-padding-top-mobile);
    }

    .header__inner {
      padding-inline: var(--layout-gutter-mobile);
    }

    .header__row {
      align-items: center;
      min-height: var(--header-row-height-mobile);
    }

    .header__employer {
      font-size: var(--header-employer-size-mobile);
      line-height: var(--line-height-normal);
    }

  }
</style>
