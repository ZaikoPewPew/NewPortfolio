---
import ThemeWidget from "../ui/ThemeWidget.astro";
import EmployerName from "../ui/EmployerName.astro";
import { getMessages, resolveLocale } from "../../i18n";

const m = getMessages(resolveLocale(Astro.currentLocale));
---

<header class="header" data-page-enter>
  <div class="header__inner">
    <div class="header__row">
      <p class="header__employer">
        <span class="employer-prefix" data-employer-prefix>
          {m.header.employerPrefix}{" "}
        </span>
        <EmployerName label={m.header.employerLabel} />
      </p>
      <ThemeWidget />
    </div>
  </div>
</header>

<style>
  .header {
    position: relative;
    isolation: isolate;
    width: 100%;
    background: color-mix(in srgb, var(--color-bg-page) 78%, transparent);
    backdrop-filter: blur(var(--blur-header-glass)) saturate(1.4);
    -webkit-backdrop-filter: blur(var(--blur-header-glass)) saturate(1.4);
    padding-top: var(--header-padding-top-desktop);
    padding-bottom: var(--layout-header-widget-gap-desktop);
  }

  .header__inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: var(--layout-content-width);
    margin-inline: auto;
    padding-inline: var(--layout-gutter-desktop);
  }

  .header__row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: var(--space-md);
    min-height: var(--header-row-height-desktop);
  }

  .header__employer {
    margin: 0;
    font-family: var(--font-family);
    font-weight: var(--font-weight-regular);
    font-size: var(--header-employer-size-desktop);
    line-height: var(--line-height-tight);
    color: var(--color-text-primary);
    white-space: nowrap;
  }

  @media (max-width: 639px) {
    .header {
      padding-top: var(--header-padding-top-mobile);
      padding-bottom: var(--layout-header-widget-gap-mobile);
    }

    .header__inner {
      padding-inline: var(--layout-gutter-mobile);
    }

    .header__row {
      min-height: var(--header-row-height-mobile);
      align-items: center;
      flex-wrap: wrap;
    }

    .header__employer {
      font-size: var(--header-employer-size-mobile);
      line-height: var(--line-height-normal);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .header {
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      background: var(--color-bg-page);
    }
  }
</style>
